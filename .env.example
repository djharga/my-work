# Environment Configuration Example
# Copy this file to .env.local and fill in your values

# Application Settings
VITE_APP_NAME=منصة خطى
VITE_APP_VERSION=0.1.0
VITE_APP_DESCRIPTION=منصة تعليمية متطورة باللغة العربية

# API Configuration
VITE_API_BASE_URL=https://api.khuta.com
VITE_API_VERSION=v1
VITE_API_TIMEOUT=10000

# Authentication
VITE_AUTH_DOMAIN=khuta.auth0.com
VITE_AUTH_CLIENT_ID=your_auth0_client_id
VITE_AUTH_REDIRECT_URI=http://localhost:5173/callback

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SERVICE_WORKER=true
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_ENABLE_ERROR_REPORTING=true

# Development Settings
VITE_DEV_TOOLS=true
VITE_DEBUG_MODE=false
VITE_MOCK_API=false

# External Services
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
VITE_SENTRY_DSN=https://your-sentry-dsn
VITE_HOTJAR_ID=your_hotjar_id

# Social Media
VITE_FACEBOOK_APP_ID=your_facebook_app_id
VITE_TWITTER_HANDLE=@khuta_platform
VITE_LINKEDIN_COMPANY=khuta-platform

# Contact Information
VITE_SUPPORT_EMAIL=support@khuta.com
VITE_CONTACT_PHONE=+966500000000
VITE_WHATSAPP_NUMBER=966500000000

# CDN and Assets
VITE_CDN_URL=https://cdn.khuta.com
VITE_ASSETS_VERSION=v1.0.0

# Performance
VITE_BUNDLE_ANALYZER=false
VITE_COMPRESSION=true
VITE_TREE_SHAKING=true